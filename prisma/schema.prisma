
generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url = env("DATABASE_URL")
}

model User {
  id String @id @default(cuid())
  email String @unique
  tokens Int @default(30)
}

model Project {
  id String @id @default(cuid())
  name String
  deployUrl String?
  framework String?
}
